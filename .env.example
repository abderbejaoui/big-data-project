# ---------- Kafka ----------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:29092
KAFKA_TOPIC_ORDERS=raw.orders
KAFKA_TOPIC_CLICKS=raw.clicks

# ---------- Producer ----------
EVENTS_PER_SECOND=5
PRODUCER_LOG_LEVEL=INFO

# ---------- Spark ----------
SPARK_MASTER=local[*]
BRONZE_PATH=/data/bronze
SILVER_PATH=/data/silver
GOLD_PATH=/data/gold
CHECKPOINT_PATH=/data/checkpoints
STREAM_TRIGGER_SECONDS=5

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000
API_INTERNAL_URL=http://fastapi:8000
API_PUBLIC_URL=http://localhost:8000

# ---------- Dashboard ----------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/stream
